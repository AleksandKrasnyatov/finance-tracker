<?xml version="1.0"?>
<ruleset name="FinanceTracker">
    <arg name="basepath" value="."/>
    <arg name="colors"/>
    <arg value="np"/>

    <file>src</file>
    <file>tests</file>

    <exclude-pattern>*/Infrastructure/Doctrine/Migration/*</exclude-pattern>

    <rule ref="PSR12">
        <exclude name="Generic.Files.LineLength"/>
    </rule>

    <rule ref="Generic.Files.LineLength">
        <exclude-pattern>*/tests/*</exclude-pattern>
    </rule>

    <rule ref="PSR2.Methods.MethodDeclaration">
        <exclude-pattern>*/tests/*</exclude-pattern>
    </rule>
</ruleset>
