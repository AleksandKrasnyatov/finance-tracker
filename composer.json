{
    "name": "aleksand-krasnyatov/finance-tracker",
    "type": "project",
    "autoload": {
      "psr-4": {
        "App\\": "src/"
      }
    },
    "autoload-dev": {
      "psr-4": {
        "Test\\": "tests/"
      }
    },
    "require": {
      "slim/slim": "^4.15",
      "slim/psr7": "^1.8",
      "webmozart/assert": "^2.4",
      "zircote/swagger-php": "^5.0",
      "slim/twig-view": "^3.0",
      "php-di/php-di": "^7.0",
      "ramsey/uuid": "^4.9",
      "predis/predis": "^2.0"
    },
    "require-dev": {
      "phpunit/phpunit": "^13.0",
      "squizlabs/php_codesniffer": "^4.0",
      "phpstan/phpstan": "^2.1",
      "overtrue/phplint": "^9.7"
    },
    "scripts": {
      "lint": "phplint",
      "cs-check": "phpcs src",
      "cs-fix": "phpcbf src",
      "phpstan": "phpstan analyse src --level=max",
      "test": "phpunit --colors=always",
      "test-coverage": "phpunit --colors=always --coverage-text"
    }
}
