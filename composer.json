{
    "name": "aleksand-krasnyatov/finance-tracker",
    "type": "project",
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Test\\": "tests/"
        }
    },
    "require": {
        "php": ">=8.4",
        "slim/slim": "^4.15",
        "slim/psr7": "^1.8",
        "webmozart/assert": "^2.4",
        "zircote/swagger-php": "^5.0",
        "slim/twig-view": "^3.0",
        "php-di/php-di": "^7.0",
        "ramsey/uuid": "^4.9",
        "predis/predis": "^2.0",
        "doctrine/orm": "^3.6",
        "symfony/console": "^8.1",
        "laminas/laminas-config-aggregator": "^1.20",
        "doctrine/migrations": "^3.9",
        "nutgram/nutgram": "^4.47",
        "symfony/cache": "^8.1",
        "monolog/monolog": "^3.10",
        "symfony/translation": "^8.1",
        "symfony/yaml": "^8.1"
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "^4.0",
        "phpstan/phpstan": "^2.1",
        "overtrue/phplint": "^9.7",
        "codeception/codeception": "^5.3",
        "codeception/module-phpbrowser": "*",
        "codeception/module-asserts": "*",
        "codeception/module-doctrine": "^3.3",
        "doctrine/data-fixtures": "^2.2"
    },
    "scripts": {
        "lint": "phplint",
        "cs-check": "phpcs",
        "cs-fix": "phpcbf",
        "phpstan": "phpstan analyse",
        "test": "codecept run --colors",
        "test-coverage": "XDEBUG_MODE=coverage codecept run --colors --coverage --coverage-text",
        "app": "php bin/app.php --ansi"
    }
}
